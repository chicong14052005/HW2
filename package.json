    "clsx": "^2.1.1",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
