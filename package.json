{
  "name": "chess-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Chess AI - Alpha-Beta Pruning & MCTS",
  "scripts": {
    "dev:frontend": "cd frontend && pnpm dev",
    "dev:backend": "cd backend && python main.py",
    "dev": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"yellow,cyan\" \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "install:frontend": "cd frontend && pnpm install",
    "install:backend": "pip install -r requirements.txt",
    "postinstall": "pnpm run install:frontend",
    "build": "cd frontend && pnpm build",
    "lint": "cd frontend && pnpm lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  }
}
